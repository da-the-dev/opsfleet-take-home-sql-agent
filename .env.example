# --- Model provider ----------------------------------------------------------
# gemini (default) | ollama | openrouter
LLM_PROVIDER=gemini

# gemini: API key from Google AI Studio (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
#GEMINI_MODEL=gemini-2.5-flash
#EMBEDDING_MODEL=models/gemini-embedding-001

# ollama: local models, no API key. Pull a tool-calling-capable model first:
#   ollama pull qwen3:8b && ollama pull nomic-embed-text
#OLLAMA_MODEL=qwen3:8b
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# openrouter: primary when LLM_PROVIDER=openrouter; with any other provider a
# set key enables automatic failover to OpenRouter on provider outages (§4.5)
#OPENROUTER_API_KEY=
#OPENROUTER_MODEL=google/gemini-2.5-flash

# --- BigQuery (required for all providers) ------------------------------------
# GCP project to bill BigQuery jobs to (public-data queries still need one).
# Must match the project from `gcloud auth application-default login`.
GOOGLE_CLOUD_PROJECT=

# --- Optional ------------------------------------------------------------------
# Langfuse tracing (design §4.7) — leave unset to run untraced
#LANGFUSE_PUBLIC_KEY=
#LANGFUSE_SECRET_KEY=
#LANGFUSE_HOST=https://cloud.langfuse.com

# Cost budgets
#MAX_BYTES_BILLED=2147483648
#MAX_SQL_ATTEMPTS=3
